name: feature_engineering
python_env: python_env.yaml

entry_points:
  main:
    parameters:
      input_artifact:
        description: W&B artifact name for the cleaned dataset (e.g. house_ts_cleaned:latest)
        type: string
      output_artifact:
        description: Name of the W&B artifact to create for the feature-engineered dataset
        type: string
      output_type:
        description: W&B artifact type (e.g. feature_dataset)
        type: string
      output_description:
        description: Human-readable description of what this artifact contains
        type: string
      pipeline_run_id:
        description: Shared ID linking all component runs in one pipeline execution
        type: string
        default: ""
    command: >-
      python run.py
        --input_artifact {input_artifact}
        --output_artifact {output_artifact}
        --output_type {output_type}
        --output_description {output_description}
        --pipeline_run_id {pipeline_run_id}
